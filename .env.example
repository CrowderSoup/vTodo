SECRET_KEY=change-me-in-production
DEBUG=True
DATABASE_URL=postgres://vtodo:vtodo@localhost:5432/vtodo
CELERY_BROKER_URL=redis://localhost:6379/0
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000
INDIEAUTH_CLIENT_ID=http://localhost:8000/

# Email (use console backend for local dev, SMTP for production)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
# Port 587 → set EMAIL_USE_TLS=True  (STARTTLS)
# Port 465 → set EMAIL_USE_SSL=True  (implicit SSL) — do NOT also set EMAIL_USE_TLS=True
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=vtodo <noreply@example.com>
